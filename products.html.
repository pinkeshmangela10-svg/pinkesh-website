<button onclick="sendCODOrder()" 
style="background-color:#28a745;color:white;padding:12px;border:none;border-radius:6px;font-size:16px;width:100%;cursor:pointer;">
Place COD Order
</button>


<div style="margin-top:20px;">

<h3>Cash on Delivery</h3>

<input type="text" id="cod_name" placeholder="Full Name" required 
style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:5px;">

<input type="tel" id="cod_phone" placeholder="Phone Number" required 
style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:5px;">

<textarea id="cod_address" placeholder="Full Address" required 
style="width:100%;padding:10px;margin-bottom:8px;border:1px solid #ccc;border-radius:5px;"></textarea>

<input type="text" id="cod_pincode" placeholder="Pincode" required 
style="width:100%;padding:10px;margin-bottom:10px;border:1px solid #ccc;border-radius:5px;">

<button onclick="sendCODOrder()" 
style="background-color:#28a745;color:white;padding:12px;border:none;border-radius:6px;font-size:16px;width:100%;cursor:pointer;">
Place COD Order
</button>

</div>

<script>
function sendCODOrder(){

var name = document.getElementById("cod_name").value;
var phone = document.getElementById("cod_phone").value;
var address = document.getElementById("cod_address").value;
var pincode = document.getElementById("cod_pincode").value;

if(name=="" || phone=="" || address=="" || pincode==""){
alert("Please fill all details");
return;
}

// Auto Order ID
var orderID = "ORD" + Math.floor(Math.random()*100000);

// Date & Time
var today = new Date();
var dateTime = today.toLocaleString();

var message = 
"🛒 New COD Order%0A%0A" +
"Order ID: " + orderID + "%0A" +
"Date: " + dateTime + "%0A%0A" +
"Product: Pinkesh Official Product%0A" +
"Price: ₹999%0A%0A" +
"Customer Details:%0A" +
"Name: " + name + "%0A" +
"Phone: " + phone + "%0A" +
"Address: " + address + "%0A" +
"Pincode: " + pincode;

var whatsappURL = "https://wa.me/918200850002?text=" + message;

window.open(whatsappURL, "_blank");
}
</script>