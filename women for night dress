<div class="product-card" style="border:1px solid #ccc; padding:15px; width:300px; margin:10px;">
    <!-- Product Image -->
    <img src="product-image.jpg" alt="Product Name" style="width:100%; height:auto;">

    <!-- Product Info -->
    <h3>Product Name</h3>
    <p>Price: ₹7999</p>

    <!-- Pay Now Button -->
    <a href="https://your-razorpay-link.com" target="_blank" 
       style="display:block; text-align:center; padding:10px; background:green; color:white; border-radius:5px; text-decoration:none; margin-bottom:10px;">
       Pay Now ₹7999
    </a>

    <!-- COD Form -->
    <h4>Cash on Delivery</h4>
    <input type="text" placeholder="Full Name" style="width:100%; padding:10px; margin-bottom:8px;" required>
    <input type="tel" placeholder="Phone Number" style="width:100%; padding:10px; margin-bottom:8px;" required>
    <input type="text" placeholder="Full Address" style="width:100%; padding:10px; margin-bottom:8px;" required>
    <input type="text" placeholder="Pincode" style="width:100%; padding:10px; margin-bottom:8px;" required>
    <button style="width:100%; padding:10px; background:blue; color:white; border:none; border-radius:5px;">
        Place COD Order
    </button>
</div>